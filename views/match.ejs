<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/match.css">
    <link rel="stylesheet" href="/css/font.css">
    <title>Document</title>
</head>
<body>
    <div class="con">
        <div class="title center">
            مسابقة كأس جامعة الأنبار للتحدي المعرفي الرقمي
        </div>

        <div class="body center">
            <div class="team teamA">
                <div class="icon logoA"></div>
                <p class="teamName nameA">اسم الكلية</p>
                <div class="leader leaderA"><img src="/img/womanLogo.jpg" alt=""></div>
                <div class="memberTeam memberA">
                    <div class="member"><img src="/img/manLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/womanLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/manLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/womanLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/manLogo.jpg" alt=""></div>
                </div>
            </div>
            <span class="vs">vs</span>
            <div class="team teamB">
                <div class="icon logoB"></div>
                <p class="teamName nameB">اسم الكلية</p>
                <div class="leader leaderB"><img src="/img/manLogo.jpg" alt=""></div>
                <div class="memberTeam memberB">
                    <div class="member"><img src="/img/manLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/womanLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/manLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/womanLogo.jpg" alt=""></div>
                    <div class="member"><img src="/img/manLogo.jpg" alt=""></div>
                </div>
            </div>
        </div>
        <div class="bgShape"><img src="/img/bgShape.png" alt="bgShape"></div>
    </div>


    <script src="/socket.io/socket.io.js"></script>
    <script src="/match.js"></script>
</body>
</html>